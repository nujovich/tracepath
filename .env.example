# Tracepath — environment configuration example
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (it is gitignored). Keep secrets out of version control.

# ─────────────────────────────────────────────────────────────
# Audit Gateway (Rust)
# ─────────────────────────────────────────────────────────────
# Ed25519 audit signing key — 32-byte hex (64 hex chars).
# Generate a fresh one with:  openssl rand -hex 32
AUDIT_SIGNING_KEY=

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://tracepath:CHANGE_ME@localhost:5432/tracepath

# Compiled OPA policy bundle
POLICY_BUNDLE_PATH=./policies/bundle.tar.gz

# NATS JetStream
NATS_URL=nats://localhost:4222

# ─────────────────────────────────────────────────────────────
# Observability — OpenTelemetry / LangFuse
# ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=tracepath-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────
# Incident Response (Python) — semantic classification
# ─────────────────────────────────────────────────────────────
INCIDENT_HTTP_PORT=8090
INCIDENTS_FILE=./incidents.jsonl

# Provider: set ONE of the following.
# Google AI (Gemini) direct:
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_CACHE_FILE=./gemini_cache.json
# OpenRouter (alternative gateway to Gemini):
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ─────────────────────────────────────────────────────────────
# Policy Evolution (Python)
# ─────────────────────────────────────────────────────────────
POLICY_API_PORT=8091
OPA_BIN=opa

# ─────────────────────────────────────────────────────────────
# WORM storage — S3 / MinIO Object Lock
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=tracepath-worm
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────
# SDK clients
# ─────────────────────────────────────────────────────────────
TRACEPATH_GATEWAY_URL=http://localhost:8080
